{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OEEMessage",
  "description": "One OEE reading from a single machine. OEE = (A x P x Q) / 10000",
  "type": "object",
  "required": [
    "machine_id", "message_id", "timestamp", "shift", "lot_id",
    "planned_production_time_min", "downtime_min",
    "ideal_cycle_time_min", "total_pieces_run", "good_pieces",
    "availability", "performance", "quality", "oee", "loss_category"
  ],
  "additionalProperties": false,
  "properties": {
    "machine_id":                  { "type": "string", "minLength": 1, "maxLength": 64 },
    "message_id":                  { "type": "string", "format": "uuid" },
    "timestamp":                   { "type": "number", "minimum": 0 },
    "shift":                       { "type": "string", "enum": ["morning", "afternoon", "night"] },
    "lot_id":                      { "type": "string" },
    "planned_production_time_min": { "type": "number", "minimum": 0 },
    "downtime_min":                { "type": "number", "minimum": 0 },
    "ideal_cycle_time_min":        { "type": "number", "minimum": 0 },
    "total_pieces_run":            { "type": "number", "minimum": 0 },
    "good_pieces":                 { "type": "number", "minimum": 0 },
    "availability":  { "type": "number", "minimum": 0, "maximum": 100 },
    "performance":   { "type": "number", "minimum": 0, "maximum": 100 },
    "quality":       { "type": "number", "minimum": 0, "maximum": 100 },
    "oee":           { "type": "number", "minimum": 0, "maximum": 100 },
    "loss_category": {
      "type": "object",
      "required": ["name", "type", "component"],
      "properties": {
        "name":      { "type": "string" },
        "type":      { "type": "string",
                       "enum": ["planned_downtime","setup_changeover","unplanned_downtime",
                                "minor_stoppage","reduced_speed","rejects_rework",
                                "startup_yield_loss","none"] },
        "component": { "type": "string",
                       "enum": ["availability","performance","quality","none"] }
      },
      "additionalProperties": false
    }
  }
}
